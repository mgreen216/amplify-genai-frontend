# Authentication Configuration
NEXTAUTH_SECRET=insecure_dev_secret_please_change_in_production
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_NEXTAUTH_URL=http://localhost:3000

# Auth Mode - Set to true to disable authentication for demo/development
NEXT_PUBLIC_AUTH_DISABLED=true

# AWS Cognito Configuration (Optional - only needed if AUTH_DISABLED=false)
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=

# API Configuration - Enable Mock Mode for Development
NEXT_PUBLIC_USE_MOCK_API=true
USE_MOCK_API=true

# Chat Configuration
# For client-side access, this must be prefixed with NEXT_PUBLIC_
# and include the full URL for development
NEXT_PUBLIC_CHAT_ENDPOINT=http://localhost:3000/api/v1/chat/completions
CHAT_ENDPOINT=http://localhost:3000/api/v1/chat/completions

# Analytics (Optional - leave empty for local development)
MIXPANEL_TOKEN=

# Local Services Configuration
# Format: service_name:port:stage (comma separated)
# Example: memory:3015:dev,auth:3016:dev
NEXT_PUBLIC_LOCAL_SERVICES=

# OpenAI Configuration (Optional - for AI features)
OPENAI_API_KEY=
OPENAI_API_HOST=https://api.openai.com
OPENAI_API_TYPE=openai
DEFAULT_MODEL=gpt-3.5-turbo

# Google Search Configuration (Optional)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Development Server Port (Optional - defaults to 3000)
# PORT=3000