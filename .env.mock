# Mock Mode Configuration
# This file enables mock mode for the application
# Copy this to .env.local to use mock endpoints

# Enable mock API mode
NEXT_PUBLIC_USE_MOCK_API=true
USE_MOCK_API=true

# Authentication (NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=mock-secret-key-for-development-only

# Mock user session
MOCK_USER_EMAIL=user@example.com
MOCK_USER_NAME=Mock User

# Feature flags for mock mode
NEXT_PUBLIC_CHAT_ENABLED=true
NEXT_PUBLIC_ARTIFACTS_ENABLED=true
NEXT_PUBLIC_ASSISTANTS_ENABLED=true
NEXT_PUBLIC_INTEGRATIONS_ENABLED=true
NEXT_PUBLIC_ADMIN_PANEL_ENABLED=false
NEXT_PUBLIC_CODE_INTERPRETER_ENABLED=false
NEXT_PUBLIC_RAG_ENABLED=true
NEXT_PUBLIC_MEMORY_ENABLED=true
NEXT_PUBLIC_WORKFLOWS_ENABLED=false
NEXT_PUBLIC_MARKETPLACE_ENABLED=true
NEXT_PUBLIC_SHARING_ENABLED=true
NEXT_PUBLIC_API_KEYS_ENABLED=true

# Application settings
NEXT_PUBLIC_DEFAULT_MODEL=gpt-3.5-turbo
NEXT_PUBLIC_DEFAULT_TEMPERATURE=0.7
NEXT_PUBLIC_DEFAULT_SYSTEM_PROMPT=You are a helpful assistant.
NEXT_PUBLIC_MAX_TOKENS=2048

# Mock OAuth providers (disabled in mock mode)
GOOGLE_CLIENT_ID=mock-google-client-id
GOOGLE_CLIENT_SECRET=mock-google-client-secret
GITHUB_CLIENT_ID=mock-github-client-id
GITHUB_CLIENT_SECRET=mock-github-client-secret

# Analytics (disabled in mock mode)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_MIXPANEL_TOKEN=

# File upload settings
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_ALLOWED_FILE_TYPES=.pdf,.txt,.md,.csv,.json,.xml,.html,.doc,.docx,.xls,.xlsx,.ppt,.pptx

# Rate limiting
NEXT_PUBLIC_RATE_LIMIT_REQUESTS_PER_MINUTE=60
NEXT_PUBLIC_RATE_LIMIT_TOKENS_PER_MINUTE=40000

# UI Settings
NEXT_PUBLIC_APP_NAME=Amplify GenAI (Mock Mode)
NEXT_PUBLIC_DEFAULT_THEME=dark
NEXT_PUBLIC_SHOW_BRAND=true